@* Components/Shared/WellHeaderPanel.razor *@
@inject IWellService WellService
@inject IProjectService ProjectService
@inject ISnackbar Snackbar

@if (IsOpen && wellHeader != null)
{
    <MudPaper Elevation="4"
              Style="width:100%; height:100%; overflow-y:auto; padding:16px;">

        @* Header *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.h6" Style="flex:1">@wellHeader.UWI</MudText>
            @if (isDirty)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Save"
                               Size="Size.Small"
                               Color="Color.Primary"
                               Title="Save changes"
                               OnClick="SaveChanges" />
                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                               Size="Size.Small"
                               Color="Color.Default"
                               Title="Discard changes"
                               OnClick="CancelChanges" />
            }
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="Close" />
        </MudStack>

        <MudDivider Class="mb-2" />

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudTabs Elevation="0" Rounded="false" PanelClass="pt-3">

                <MudTabPanel Text="Well Header">
                    <WellHeaderTab @ref="wellHeaderTab"
                                   EditCopy="editCopy"
                                   OnFieldChanged="MarkDirty"
                                   Operators="operators"
                                   Statuses="statuses"
                                   ProfileTypes="profileTypes"
                                   OnAddOperator="AddOperator"
                                   OnAddStatus="AddStatus"
                                   OnAddProfileType="AddProfileType" />
                </MudTabPanel>

                <MudTabPanel Text="Location">
                    <WellLocationTab @ref="wellLocationTab"
                                     EditCopy="editCopy"
                                     OnFieldChanged="MarkDirty"
                                     SelectedState="selectedState"
                                     SelectedStateChanged="OnStateChanged"
                                     SelectedCounty="selectedCounty"
                                     SelectedCountyChanged="OnCountyChanged"
                                     SearchStates="SearchStates"
                                     SearchCounties="SearchCounties"
                                     OnAddNewState="AddNewState"
                                     OnAddNewCounty="AddNewCounty" />
                </MudTabPanel>

            </MudTabs>
        }
    </MudPaper>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string? UWI { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<WellHeader> OnSaved { get; set; }

    private WellHeader? wellHeader;
    private WellHeader editCopy = new();
    private bool isLoading = false;
    private bool isDirty = false;
    private AreaItem? selectedState = null;
    private AreaItem? selectedCounty = null;

    // Refs so we can call ResetState() on child UI when cancelling
    private WellHeaderTab? wellHeaderTab;
    private WellLocationTab? wellLocationTab;

    private IEnumerable<string> operators = Enumerable.Empty<string>();
    private IEnumerable<string> statuses = Enumerable.Empty<string>();
    private IEnumerable<string> profileTypes = Enumerable.Empty<string>();

    private string GetConnectionString() =>
        ProjectService.SelectedProject!.BuildConnectionString(
            ProjectService.GetPassword(ProjectService.SelectedProject.Id));

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && UWI != null)
            await LoadWellHeader();
    }

    private async Task LoadWellHeader()
    {
        if (ProjectService.SelectedProject == null) return;

        try
        {
            isLoading = true;
            var cs = GetConnectionString();

            wellHeader = await WellService.GetWellHeaderAsync(cs, UWI!);
            ResetEditCopy();

            var refTasks = new[]
            {
            WellService.GetReferenceValuesAsync(cs, "BUSINESS_ASSOCIATE", "BUSINESS_ASSOCIATE_ID"),
            WellService.GetReferenceValuesAsync(cs, "R_WELL_STATUS",      "STATUS"),
            WellService.GetReferenceValuesAsync(cs, "R_WELL_PROFILE_TYPE","WELL_PROFILE_TYPE"),
        };
            var results = await Task.WhenAll(refTasks);
            operators = results[0];
            statuses = results[1];
            profileTypes = results[2];

            // Always reset first, then load if values exist
            selectedState = null;
            selectedCounty = null;

            if (!string.IsNullOrWhiteSpace(wellHeader?.STATE))
                selectedState = await WellService.GetAreaByIdAsync(cs, wellHeader.STATE, "STATE");

            if (!string.IsNullOrWhiteSpace(wellHeader?.COUNTY))
                selectedCounty = await WellService.GetAreaByIdAsync(cs, wellHeader.COUNTY, "COUNTY");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading well header: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetEditCopy()
    {
        if (wellHeader == null) return;
        editCopy = CopyHeader(wellHeader);
        isDirty = false;
        wellHeaderTab?.ResetState();
        wellLocationTab?.ResetState();
    }

    private void MarkDirty() => isDirty = true;

    private void OnStateChanged(AreaItem? state)
    {
        selectedState = state;
        editCopy.STATE = state?.AreaId;
        // Clear county when state changes
        selectedCounty = null;
        editCopy.COUNTY = null;
        MarkDirty();
    }

    private async Task<IEnumerable<AreaItem>> SearchStates(string search, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(search)) return Enumerable.Empty<AreaItem>();
        return await WellService.SearchStatesAsync(GetConnectionString(), search);
    }

    private async Task<IEnumerable<AreaItem>> SearchCounties(string search, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(search) || selectedState == null)
            return Enumerable.Empty<AreaItem>();
        return await WellService.SearchCountiesAsync(
            GetConnectionString(), selectedState.AreaId, search);
    }

    private async Task SaveChanges()
    {
        if (ProjectService.SelectedProject == null) return;

        try
        {
            isLoading = true;
            await WellService.UpdateWellHeaderAsync(GetConnectionString(), editCopy);
            wellHeader = CopyHeader(editCopy);
            isDirty = false;
            Snackbar.Add("Well header saved.", Severity.Success);
            await OnSaved.InvokeAsync(editCopy);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving well header: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CancelChanges()
    {
        ResetEditCopy();
        if (!string.IsNullOrWhiteSpace(wellHeader?.STATE))
        {
            _ = Task.Run(async () =>
            {
                selectedState = await WellService.GetAreaByIdAsync(
                    GetConnectionString(), wellHeader.STATE, "STATE");
                selectedCounty = !string.IsNullOrWhiteSpace(wellHeader?.COUNTY)
                    ? await WellService.GetAreaByIdAsync(GetConnectionString(), wellHeader.COUNTY, "COUNTY")
                    : null;
                await InvokeAsync(StateHasChanged);
            });
        }
        else
        {
            selectedState = null;
            selectedCounty = null;
        }
        Snackbar.Add("Changes discarded.", Severity.Info);
    }

    private async Task Close()
    {
        if (isDirty) CancelChanges();
        wellHeader = null;
        await OnClose.InvokeAsync();
    }

    private async Task AddOperator(string name)
    {
        var cs = GetConnectionString();
        await WellService.AddReferenceValueAsync(cs, "BUSINESS_ASSOCIATE", "BUSINESS_ASSOCIATE_ID", name);
        operators = await WellService.GetReferenceValuesAsync(cs, "BUSINESS_ASSOCIATE", "BUSINESS_ASSOCIATE_ID");
        Snackbar.Add($"Operator '{name}' added.", Severity.Success);
    }

    private async Task AddStatus(string name)
    {
        var cs = GetConnectionString();
        await WellService.AddReferenceValueAsync(cs, "R_WELL_STATUS", "STATUS", name);
        statuses = await WellService.GetReferenceValuesAsync(cs, "R_WELL_STATUS", "STATUS");
        Snackbar.Add($"Status '{name}' added.", Severity.Success);
    }

    private async Task AddProfileType(string name)
    {
        var cs = GetConnectionString();
        await WellService.AddReferenceValueAsync(cs, "R_WELL_PROFILE_TYPE", "WELL_PROFILE_TYPE", name);
        profileTypes = await WellService.GetReferenceValuesAsync(cs, "R_WELL_PROFILE_TYPE", "WELL_PROFILE_TYPE");
        Snackbar.Add($"Profile type '{name}' added.", Severity.Success);
    }

    private async Task AddNewState(AreaItem newState)
    {
        try
        {
            var cs = GetConnectionString();
            await WellService.AddAreaAsync(cs, "STATE", newState.AreaId, newState.PreferredName);
            OnStateChanged(newState);
            Snackbar.Add($"State '{newState.PreferredName}' added.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding state: {ex.Message}", Severity.Error);
        }
    }

    private async Task AddNewCounty(AreaItem newCounty)
    {
        if (selectedState == null) return;
        try
        {
            var cs = GetConnectionString();
            await WellService.AddCountyAsync(cs, newCounty.AreaId, newCounty.PreferredName, selectedState.AreaId);
            OnCountyChanged(newCounty);
            Snackbar.Add($"County '{newCounty.PreferredName}' added.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding county: {ex.Message}", Severity.Error);
        }
    }

    private void OnCountyChanged(AreaItem? county)
    {
        selectedCounty = county;
        editCopy.COUNTY = county?.AreaId;
        MarkDirty();
    }



    private static decimal? ParseNullableDecimal(string? value) =>
        decimal.TryParse(value, out var d) ? d : null;

    private WellHeader CopyHeader(WellHeader src) => new WellHeader
    {
        UWI                   = src.UWI,
        WELL_NAME             = src.WELL_NAME,
        OPERATOR              = src.OPERATOR,
        CURRENT_STATUS        = src.CURRENT_STATUS,
        PROFILE_TYPE          = src.PROFILE_TYPE,
        DEPTH_DATUM           = src.DEPTH_DATUM,
        KB_ELEV               = src.KB_ELEV,
        GROUND_ELEV           = src.GROUND_ELEV,
        FINAL_TD              = src.FINAL_TD,
        LOG_TD                = src.LOG_TD,
        DRILL_TD              = src.DRILL_TD,
        MAX_TVD               = src.MAX_TVD,
        SPUD_DATE             = src.SPUD_DATE,
        FINAL_DRILL_DATE      = src.FINAL_DRILL_DATE,
        COMPLETION_DATE       = src.COMPLETION_DATE,
        ABANDONMENT_DATE      = src.ABANDONMENT_DATE,
        SURFACE_LATITUDE      = src.SURFACE_LATITUDE,
        SURFACE_LONGITUDE     = src.SURFACE_LONGITUDE,
        BOTTOM_HOLE_LATITUDE  = src.BOTTOM_HOLE_LATITUDE,
        BOTTOM_HOLE_LONGITUDE = src.BOTTOM_HOLE_LONGITUDE,
        REMARK                = src.REMARK,
        STATE                 = src.STATE,
        COUNTY                = src.COUNTY
    };
}