@inject IWellService WellService
@inject IProjectService ProjectService
@inject ISnackbar Snackbar

@if (IsOpen && wellHeader != null)
{
    <MudPaper Elevation="4"
              Style="width:100%; height:100%; overflow-y:auto; padding:16px;">

        @* Header *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.h6" Style="flex:1">@wellHeader.UWI</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="Close" />
        </MudStack>

        <MudDivider Class="mb-4" />

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            @* IDENTIFICATION *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                IDENTIFICATION
            </MudText>
            <MudGrid Spacing="1" Class="mb-4">
                <MudItem xs="12">
                    <MudField Label="Well Name" Variant="Variant.Text">
                        @wellHeader.WELL_NAME
                    </MudField>
                </MudItem>
                <MudItem xs="12">
                    <MudField Label="Operator" Variant="Variant.Text">
                        @wellHeader.OPERATOR
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="Current Status" Variant="Variant.Text">
                        @wellHeader.CURRENT_STATUS
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="Profile Type" Variant="Variant.Text">
                        @wellHeader.PROFILE_TYPE
                    </MudField>
                </MudItem>
                <MudItem xs="12">
                    <MudField Label="Environment Type" Variant="Variant.Text">
                        @wellHeader.ENVIRONMENT_TYPE
                    </MudField>
                </MudItem>
            </MudGrid>

            @* LOCATION *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                LOCATION
            </MudText>
            <MudGrid Spacing="1" Class="mb-4">
                <MudItem xs="6">
                    <MudField Label="Country" Variant="Variant.Text">
                        @wellHeader.COUNTRY
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="State/Province" Variant="Variant.Text">
                        @wellHeader.STATE
                    </MudField>
                </MudItem>
                <MudItem xs="12">
                    <MudField Label="County" Variant="Variant.Text">
                        @wellHeader.COUNTY
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="Surface Latitude" Variant="Variant.Text">
                        @wellHeader.SURFACE_LATITUDE
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="Surface Longitude" Variant="Variant.Text">
                        @wellHeader.SURFACE_LONGITUDE
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="BH Latitude" Variant="Variant.Text">
                        @wellHeader.BOTTOM_HOLE_LATITUDE
                    </MudField>
                </MudItem>
                <MudItem xs="6">
                    <MudField Label="BH Longitude" Variant="Variant.Text">
                        @wellHeader.BOTTOM_HOLE_LONGITUDE
                    </MudField>
                </MudItem>
            </MudGrid>

            @* DATES *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">DATES</MudText>
            <div style="display:flex; gap:16px; flex-wrap:nowrap; margin-bottom:16px;">
                <div style="width:130px; min-width:130px;">
                    <MudField Label="Spud Date" Variant="Variant.Text">@wellHeader.SPUD_DATE?.ToString("yyyy-MM-dd")</MudField>
                </div>
                <div style="width:130px; min-width:130px;">
                    <MudField Label="Final Drill" Variant="Variant.Text">@wellHeader.FINAL_DRILL_DATE?.ToString("yyyy-MM-dd")</MudField>
                </div>
                <div style="width:130px; min-width:130px;">
                    <MudField Label="Completion" Variant="Variant.Text">@wellHeader.COMPLETION_DATE?.ToString("yyyy-MM-dd")</MudField>
                </div>
                <div style="width:130px; min-width:130px;">
                    <MudField Label="Abandonment" Variant="Variant.Text">@wellHeader.ABANDONMENT_DATE?.ToString("yyyy-MM-dd")</MudField>
                </div>
            </div>

            @* DEPTHS *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">DEPTHS</MudText>
            <div style="display:flex; gap:16px; flex-wrap:nowrap; margin-bottom:16px;">
                <div style="width:120px; min-width:120px;">
                    <MudField Label="Final TD" Variant="Variant.Text">@wellHeader.FINAL_TD</MudField>
                </div>
                <div style="width:120px; min-width:120px;">
                    <MudField Label="Log TD" Variant="Variant.Text">@wellHeader.LOG_TD</MudField>
                </div>
                <div style="width:120px; min-width:120px;">
                    <MudField Label="Drill TD" Variant="Variant.Text">@wellHeader.DRILL_TD</MudField>
                </div>
                <div style="width:120px; min-width:120px;">
                    <MudField Label="Max TVD" Variant="Variant.Text">@wellHeader.MAX_TVD</MudField>
                </div>
            </div>

            @* ELEVATIONS *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">ELEVATIONS</MudText>
            <div style="display:flex; gap:16px; flex-wrap:nowrap; margin-bottom:16px;">
                <div style="width:140px; min-width:140px;">
                    <MudField Label="Depth Datum" Variant="Variant.Text">@wellHeader.DEPTH_DATUM</MudField>
                </div>
                <div style="width:120px; min-width:120px;">
                    <MudField Label="KB Elevation" Variant="Variant.Text">@wellHeader.KB_ELEV</MudField>
                </div>
                <div style="width:140px; min-width:140px;">
                    <MudField Label="Ground Elevation" Variant="Variant.Text">@wellHeader.GROUND_ELEV</MudField>
                </div>
            </div>

            @* REMARKS *@
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                REMARKS
            </MudText>
            <MudField Label="Remark" Variant="Variant.Text"
                      Style="white-space:pre-wrap; min-height:80px;">
                @wellHeader.REMARK
            </MudField>
        }
    </MudPaper>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string? UWI { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private WellHeader? wellHeader;
    private bool isLoading = false;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && UWI != null)
            await LoadWellHeader();
    }

    private async Task LoadWellHeader()
    {
        if (ProjectService.SelectedProject == null) return;

        try
        {
            isLoading = true;
            var connectionString = ProjectService.SelectedProject.BuildConnectionString(
                ProjectService.GetPassword(ProjectService.SelectedProject.Id));

            wellHeader = await WellService.GetWellHeaderAsync(connectionString, UWI!);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading well header: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Close()
    {
        wellHeader = null;
        await OnClose.InvokeAsync();
    }
}