<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsNew ? "New Project" : "Edit Project")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">

            <MudTextField @bind-Value="Project.Name"
                          Label="Project Name"
                          Required="true"
                          RequiredError="Project name is required"
                          Class="mb-4" />

            <MudTextField @bind-Value="Project.Description"
                          Label="Description"
                          Lines="2"
                          Class="mb-4" />

            <MudTextField @bind-Value="Project.Server"
                          Label="Server"
                          Required="true"
                          RequiredError="Server is required"
                          Placeholder="e.g. localhost or MyServer\SQLEXPRESS"
                          Class="mb-4" />

            <MudTextField @bind-Value="Project.Database"
                          Label="Database"
                          Required="true"
                          RequiredError="Database is required"
                          Placeholder="e.g. PPDM"
                          Class="mb-4" />

            <MudSwitch @bind-Value="Project.UseWindowsAuthentication"
                       Label="Use Windows Authentication"
                       Color="Color.Primary"
                       Class="mb-4" />

            @if (!Project.UseWindowsAuthentication)
            {
                <MudTextField @bind-Value="Project.Username"
                              Label="Username"
                              Required="true"
                              RequiredError="Username is required"
                              Class="mb-4" />

                <MudTextField @bind-Value="password"
                              Label="Password"
                              InputType="InputType.Password"
                              Class="mb-4" />
            }

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Project Project { get; set; } = new();

    [Parameter]
    public bool IsNew { get; set; } = false;

    [Parameter]
    public string? ExistingPassword { get; set; }

    private MudForm form = default!;
    private bool isValid;
    private string? password;

    protected override void OnInitialized()
    {
        password = ExistingPassword;
    }

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (!form.IsValid) return;

        MudDialog.Close(DialogResult.Ok((Project, password)));
    }

    private void Cancel() => MudDialog.Cancel();
}