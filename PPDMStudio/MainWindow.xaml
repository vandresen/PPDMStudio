<Window x:Class="PPDMStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        Title="PPDM Studio" Height="600" Width="900"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Help">
                <MenuItem Header="User Guide" Click="HelpUserGuide_Click" />
                <Separator />
                <MenuItem Header="About PPDMStudio" Click="HelpAbout_Click" />
            </MenuItem>
        </Menu>

        <blazor:BlazorWebView Grid.Row="1" x:Name="blazorWebView" HostPage="wwwroot\index.html" />
    </Grid>
</Window>